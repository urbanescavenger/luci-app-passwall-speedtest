msgid "<a href=\"https://github.com/urbanescavenger/luci-app-passwall-speedtest\" target=\"_blank\">⭐ Star on GitHub</a>"
msgstr "<a href=\"https://github.com/urbanescavenger/luci-app-passwall-speedtest\" target=\"_blank\">⭐ 在 GitHub 上关注</a>"

msgid "PassWall Speed Test"
msgstr "PassWall 节点测速"

msgid "Schedules and runs a PassWall node-based Cloudflare IP latency test, writing the fastest IP back to the selected passwall nodes and other integrations"
msgstr "定时通过 PassWall 节点对候选 Cloudflare IP 测延迟，把最快 IP 写回所选 passwall 节点及其它集成"

msgid "Plugin Settings"
msgstr "插件设置"

msgid "Third Party Settings"
msgstr "第三方设置"

msgid "Basic Settings"
msgstr "基础设置"

msgid "Crontab Settings"
msgstr "计划任务设置"

msgid "Logs"
msgstr "日志"

msgid "Probes candidate Cloudflare IPs through the selected passwall node(s) via a local SOCKS and measures HTTP HEAD latency (<code>time_pretransfer</code>). Only latency is measured (no download bandwidth). The fastest IP is written back to each passwall worker node."
msgstr "通过所选 passwall 节点拉起本地 SOCKS，对候选 Cloudflare IP 做 HTTP HEAD 探测取延迟（<code>time_pretransfer</code>）。只测延迟，不测下载带宽。最快 IP 会写回每个 passwall worker 节点。"

msgid "Enabled"
msgstr "启用"

msgid "Enable scheduled task to test the selected IP list"
msgstr "启用计划任务测试所选 IP 列表"

msgid "Enable custom cron"
msgstr "启用自定义 Cron"

msgid "Custom Cron"
msgstr "自定义 Cron"

msgid "Example: 0 */3 * * *"
msgstr "例如: 0 */3 * * *"

msgid "Interval"
msgstr "间隔"

msgid "Every %d hour(s)"
msgstr "每 %d 小时"

msgid "ShadowSocksR Plus+ Enabled"
msgstr "启用 ShadowSocksR Plus+"

msgid "Passwall Enabled"
msgstr "启用 Passwall"

msgid "PassWall2 Enabled"
msgstr "启用 PassWall2"

msgid "Bypass Enabled"
msgstr "启用 Bypass"

msgid "Vssr Enabled"
msgstr "启用 Vssr"

msgid "ShadowSocksR Servers"
msgstr "ShadowSocksR Plus+ 服务"

msgid "Passwall Servers"
msgstr "Passwall 服务"

msgid "Passwall2 Servers"
msgstr "Passwall2 服务"

msgid "Bypass Servers"
msgstr "Bypass 服务"

msgid "Vssr Servers"
msgstr "Vssr 服务"

msgid "Please select a service"
msgstr "请选择一项服务"

msgid "Speed test"
msgstr "测速"

msgid "Best IP"
msgstr "最佳 IP"

msgid "History Charts"
msgstr "历史图表"

msgid "Start"
msgstr "开始"

msgid "Stop"
msgstr "停止"

msgid "Latency cap (ms)"
msgstr "延迟上限 (ms)"

msgid "Discard candidate IPs whose average latency is above this threshold (measured via the node's local SOCKS)."
msgstr "丢弃平均延迟高于此阈值的候选 IP（经节点本地 SOCKS 测得）。"

msgid "Latency lower bound (ms)"
msgstr "延迟下限 (ms)"

msgid "Discard candidate IPs whose average latency is below this threshold."
msgstr "丢弃平均延迟低于此阈值的候选 IP。"

msgid "Packet loss rate cap"
msgstr "丢包率上限"

msgid "Discard candidate IPs whose packet loss ratio exceeds this value (0–1)."
msgstr "丢弃丢包率超过此值（0–1）的候选 IP。"

msgid "IP list source"
msgstr "IP 列表来源"

msgid "Select the built-in Cloudflare IP list or a custom file used as candidates"
msgstr "选择内置 Cloudflare IP 列表或自定义文件作为候选"

msgid "Built-in IPv4 list"
msgstr "内置 IPv4 列表"

msgid "Built-in IPv6 list"
msgstr "内置 IPv6 列表"

msgid "Custom file"
msgstr "自定义文件"

msgid "Custom IP list file"
msgstr "自定义 IP 列表文件"

msgid "Enter a local file path, for example: /etc/passwall-speedtest/ip.txt"
msgstr "输入本地文件路径，例如：/etc/passwall-speedtest/ip.txt"

msgid "Scan all IPs in each /24"
msgstr "扫描每个 /24 中的全部 IP"

msgid "Only applies to custom IP lists. Disabled by default: one random IP per /24 is tested. Enable to test every IP in each /24 (slower)."
msgstr "仅对自定义 IP 列表生效。默认关闭：每个 /24 只随机测 1 个 IP。开启后会扫描每个 /24 中的全部 IP（更慢）。"

msgid "Custom IP list file is required when using Custom file"
msgstr "当 IP 列表来源使用自定义文件时，必须填写自定义 IP 列表文件"

msgid "Passwall node to test through (single-node fallback)"
msgstr "用于测速的 passwall 节点（单节点回退）"

msgid "Used only when no passwall workers are selected in the Third-Party tab. Select a CF-CDN-fronted passwall node (VLESS/VMess/Trojan/SS…). Its <em>address</em> will be cycled through candidate IPs and finally set to the fastest one. SOCKS-type nodes are not supported."
msgstr "仅在「第三方设置」里未选 passwall worker 时使用。选择一个 CF-CDN 前置的 passwall 节点（VLESS/VMess/Trojan/SS…），其 <em>address</em> 会被候选 IP 轮换，最终设为最快 IP。不支持 SOCKS 类型节点。"

msgid "Probe URL"
msgstr "探测 URL"

msgid "URL probed via the node's local SOCKS; only the HTTP HEAD latency is measured. generate_204 / connectivity-check endpoints are preferred."
msgstr "经节点本地 SOCKS 探测的 URL；只测 HTTP HEAD 延迟。建议用 generate_204 / 连通性检测端点。"

msgid "Max IPs to test"
msgstr "最大测速 IP 数"

msgid "This mode tests IPs through the node (~3-7s each). Cap the count to avoid long runs; use a smaller IP list or lower this value for faster results."
msgstr "此模式经节点逐个测 IP（每个约 3-7 秒）。限制数量避免耗时过长；用更小的 IP 列表或更小的值以加快结果。"

msgid "Probe timeout (s)"
msgstr "探测超时 (秒)"

msgid "Per-IP curl <code>--max-time</code> in seconds."
msgstr "每个 IP 的 curl <code>--max-time</code>，单位秒。"

msgid "Probes per IP"
msgstr "每 IP 探测次数"

msgid "How many curl probes per candidate IP. Each probe is a full SOCKS+curl, so higher values are slower. If <strong>any</strong> single probe fails, that IP is discarded immediately and the remaining probes are skipped — only IPs that succeed on <em>all</em> probes are kept, so the best IP is a stable one."
msgstr "每个候选 IP 的 curl 探测次数。每次探测都是完整的 SOCKS+curl，次数越多越慢。<strong>任意一次</strong>探测失败该 IP 立即丢弃并跳过后续探测——只有<em>全部</em>探测都成功的 IP 才保留，确保选中的 IP 稳定。"

msgid "Max parallel workers"
msgstr "最大并发 worker"

msgid "Cap on concurrently running passwall workers (only relevant when passwall nodes are selected in the Third-Party tab). 0 means run all workers at once. Each worker runs its own SOCKS+curl chain, so high values need more RAM/CPU — keep ≤ node count and mind router limits."
msgstr "并发运行的 passwall worker 上限（仅在「第三方设置」里选了 passwall 节点时生效）。0 表示一次性跑全部 worker。每个 worker 跑自己的 SOCKS+curl 链路，并发越高越吃内存/CPU——建议 ≤ 节点数，注意路由器承受能力。"

