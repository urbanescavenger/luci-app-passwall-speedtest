config global 'global'
	option hour '24'
	option enabled '0'
	option ip_source 'builtin_ipv4'
	option custom_ip_file ''
	option custom_allip '0'
	option ip_online_url 'https://zip.cm.edu.kg/all.txt'
	option ip_online_regions 'JP SG KR'
	option tl '200'
	option tll '40'
	option tlr '0.2'
	option node_test_node ''
	option node_test_url 'https://www.google.com/generate_204'
	option node_test_count '30'
	option node_test_timeout '5'
	option node_test_probes '3'
	option node_test_threads '5'

config servers 'servers'
	option ssr_enabled '0'
	option passwall_enabled '0'
	option passwall2_enabled '0'
	option bypass_enabled '0'
	option vssr_enabled '0'
	option DNS_enabled '0'
	option AliDNS_ip_count '1'
	option AstraDNS_enabled '0'
	option AstraDNS_config '/etc/astra-dns/named.yaml'
	option AstraDNS_bin '/usr/bin/astra-dns'

# 五个固定 CM 源备选 IP 列表，共享 ip_online_url，仅 regions 不同。
# 每个 passwall worker 节点可在「第三方设置」里指派其中一个列表（node_ip 段）。
# 未指派的 worker 回退到第一个 enabled=1 的列表。
config ip_list 'list1'
	option enabled '1'
	option name 'JP/SG/KR'
	option regions 'JP SG KR'

config ip_list 'list2'
	option enabled '0'
	option name ''
	option regions ''

config ip_list 'list3'
	option enabled '0'
	option name ''
	option regions ''

config ip_list 'list4'
	option enabled '0'
	option name ''
	option regions ''

config ip_list 'list5'
	option enabled '0'
	option name ''
	option regions ''